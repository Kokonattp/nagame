# nagame — env ทั้งหมด. คัดลอกเป็น .env.local แล้วใส่ค่า (ไฟล์นี้ commit ได้ .env.local ห้าม)
#
# ทุกตัวเป็น OPTIONAL — ไม่ใส่ก็รันได้ แอปไม่พัง (dual-mode ทั้งระบบ) แต่ฟีเจอร์ที่ผูกกับ
# key นั้นจะเงียบไป. ตารางล่างบอกว่า "ไม่ใส่แล้วเสียอะไร" — เรียงตามความสำคัญจริง

# ═══════════════════════════════════════════════════════════════════
# 1. หัวใจของกร๊วก — ไม่ใส่ = ค้นหาที่พัก/ร้าน/ตั๋ว "ไม่ทำงานเลย"
# ═══════════════════════════════════════════════════════════════════

# Claude API — ใช้ 2 อย่าง: (1) กร๊วกพูดไทย (2) **อ่านเจตนาคำถาม (parseCardIntent)**
# ⚠️ ไม่ใส่ = ตกไปใช้ regex หยาบที่รู้จักแค่ "กิน/นอน/บิน" → ถาม "ทงคัตสึแถวเมืองเก่างบสองพัน"
#    จะจับไม่ได้ → wantsEat=false → **ไม่เรียก Places เลย** → ต่อให้มี GOOGLE_PLACES_API_KEY
#    ก็ไม่มีการ์ดร้านออกมา (พังเป็นทอด)
# เอาจาก: https://console.anthropic.com/ → API keys
#    (คนละตัวกับ Claude subscription — ต้องสมัคร API แยก มีเครดิตขั้นต่ำ)
# ต้นทุนจริง: Haiku ~$0.003/คำตอบ (1,000 users × 20 ข้อความ ≈ $60)
ANTHROPIC_API_KEY=

# ที่พัก — Rakuten Travel API (ทางการ ห้าม reverse)
# ไม่ใส่ = ไม่มี StayCard เลย (available:false เงียบ ๆ)
# เอาจาก: https://webservice.rakuten.co.jp/ → สมัครฟรี → Application ID
RAKUTEN_APP_ID=
# affiliate id (ถ้ามี) — ท่อรายได้ขาแรกตาม roadmap ใส่ทีหลังได้ ไม่ต้องแก้โค้ด
RAKUTEN_AFFILIATE_ID=

# ร้านอาหาร — Google Places API (New) v1 places:searchText (endpoint ทางการ ไม่ scrape)
# ไม่ใส่ = ไม่มี EatCard เลย (รวมถึง filter ฮาลาล/มังสวิรัติ/แพ้กุ้ง ที่เป็นบริบทคนไทย)
# เอาจาก: Google Cloud Console → เปิด "Places API (New)" → Credentials → API key
#    (มี free tier แต่ต้องผูกบัตร — จำกัด key ด้วย HTTP referrer/IP ด้วย)
GOOGLE_PLACES_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# 2. ตั๋วบิน — optional enrichment (ห้ามอยู่ใน critical path)
# ═══════════════════════════════════════════════════════════════════

# ไม่ใส่ = FlightCard **ยังออก** แต่ priceThb=null → โชว์ปุ่ม Google Flights แทน
# (ตั้งใจ: fail แบบซื่อสัตย์ ไม่เดาราคา — roadmap "เพื่อนที่แกล้งไม่ได้ยิน = เสียความเชื่อใจ")
FLI_API_URL=
FLI_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# 3. persistence — ไม่ใส่ = ทริป/ตรา อยู่แค่ localStorage ไม่ sync ข้ามเครื่อง
# ═══════════════════════════════════════════════════════════════════

# Supabase — เจ้าของสร้าง project เอง แล้วรัน supabase/schema.sql ใน SQL editor ก่อน
# ไม่ใส่ = /api/trip, /api/trip-meta, click-out logging → 503 เงียบ, localStorage ยังทำงาน
# ⚠️ SERVICE_KEY = ห้ามหลุดฝั่ง client (server-only ผ่าน API route เท่านั้น)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ═══════════════════════════════════════════════════════════════════
# 4. สัญญาณเสริม — ไม่ใส่ = ส่วนนั้นเงียบ ที่เหลือทำงานปกติ
# ═══════════════════════════════════════════════════════════════════

# อากาศ — ไม่ใส่ = ใช้ Open-Meteo (ฟรี ไม่ต้อง key) เป็น fallback
OPENWEATHER_API_KEY=
# ฝุ่น AQI
OPENAQ_API_KEY=
# กล้องสด — ไม่ใส่ = ใช้ YouTube livecam ที่คัดไว้ในโค้ดแทน
WINDY_WEBCAMS_API_KEY=

# LLM สำรอง (ยังไม่ใช้เป็นหลัก — ANTHROPIC เป็นตัวจริง)
AI_API_KEY=
GEMINI_API_KEY=
